{
  // dropout: 全局 dropout，作用于 attention、residual、MLP 等位置。
  // 小模型从零训练时通常先设为 0.0，等数据量较小或过拟合明显再增大。
  "dropout": 0.0,

  // bos/eos token id 必须和 tokenizer 配置保持一致。
  "bos_token_id": 1,
  "eos_token_id": 2,

  // hidden_act: FFN / MoE expert 中使用的激活函数。
  "hidden_act": "silu",

  // hidden_size: 主隐藏维度，决定 embedding、attention、MLP 的通道宽度。
  "hidden_size": 512,

  // intermediate_size: FFN 或每个 expert 的扩展维度。
  // 当前 1408 是和 hidden_size=512 匹配的合理值，也是 64 的倍数。
  "intermediate_size": 1408,

  // max_position_embeddings: 结构上支持的最大位置长度，不等于训练时真实见过的长度。
  "max_position_embeddings": 32768,

  // attention 头数。
  // 约束1: hidden_size % num_attention_heads == 0
  "num_attention_heads": 8,

  // transformer block 层数。
  "num_hidden_layers": 8,

  // KV 头数，当前配置使用 GQA 而不是标准 MHA。
  // 约束2: num_attention_heads % num_key_value_heads == 0
  "num_key_value_heads": 2,

  // vocab_size 必须和 tokenizer 词表大小完全一致。
  "vocab_size": 6400,

  // RMSNorm 的 eps，通常保持默认即可。
  "rms_norm_eps": 1e-05,

  // RoPE base。
  "rope_theta": 1000000.0,

  // 是否启用 YaRN 外推参数。
  // 只影响推理侧长上下文扩展，不等于训练真的学会了超长序列。
  "inference_rope_scaling": false,

  // 是否启用快注意力路径。
  "flash_attn": true,

  // auto: 当前仓库中默认走 PyTorch SDP，优先正确性和 backward 支持。
  // triton: 显式走自定义 Triton 实现。
  // pytorch: 显式走官方 scaled_dot_product_attention。
  // fa4: 显式走 flash-attn-4，受 GPU 架构和运行时条件限制。
  "flash_attn_impl": "auto",

  // 默认启用 MoE 架构。
  // 当 use_moe=true 时，下面这组 expert / gate 参数才生效。
  "use_moe": true,

  // 每个 token 路由到多少个 expert。
  // 约束3: num_experts_per_tok <= n_routed_experts
  "num_experts_per_tok": 2,

  // 可路由专家总数。
  "n_routed_experts": 4,

  // 共享专家数量。
  // 共享专家始终参与计算，用来增强稳定性和保底表达能力。
  "n_shared_experts": 1,

  // gate 的打分函数，当前实现默认使用 softmax。
  "scoring_func": "softmax",

  // MoE 辅助损失权重，用于鼓励 expert 负载均衡。
  // 太大可能压制主任务 loss，太小则路由容易塌缩。
  "aux_loss_alpha": 0.01,

  // 是否按序列级别计算 MoE 辅助损失。
  "seq_aux": true,

  // 是否对 top-k 路由概率做归一化。
  "norm_topk_prob": true
}